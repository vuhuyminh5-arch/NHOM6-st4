@model MilkTea.Models.Order

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow-lg p-5 rounded-4 bg-white">
            <h2 class="fw-bold mb-4" style="color: #1e3932;">Thông tin giao hàng</h2>
            <p class="text-muted mb-4">Anh Minh vui lòng điền thông tin để Chất Coffee gửi trà sữa tới tận tay nhé!</p>
            
            <form asp-action="Checkout" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Họ tên khách hàng</label>
                    <input asp-for="FullName" class="form-control rounded-pill px-4 py-2" placeholder="Ví dụ: Nguyễn Văn A" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control rounded-pill px-4 py-2" placeholder="090x xxx xxx" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                    @* Phải có asp-for="Address" và chữ required ở cuối *@
                    <textarea asp-for="Address" class="form-control rounded-4 px-4 py-2" rows="3"
                              placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-dark btn-lg rounded-pill fw-bold py-3">XÁC NHẬN ĐẶT HÀNG</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại giỏ hàng</a>
                </div>
            </form>
        </div>
    </div>
</div>
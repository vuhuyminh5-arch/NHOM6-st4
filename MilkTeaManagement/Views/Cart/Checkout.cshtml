@model MilkTea.Models.Order

<div class="container my-5" data-aos="fade-up">
    <div class="row">
        <div class="col-md-7">
            <div class="bg-white p-4 rounded-4 shadow-sm border">
                <h4 class="fw-bold mb-4">Thông tin giao hàng</h4>
                <form asp-action="Checkout" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ tên khách hàng</label>
                        <input asp-for="FullName" class="form-control rounded-pill px-4 py-2" placeholder="Ví dụ: Nguyễn Văn A" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control rounded-pill px-4 py-2" placeholder="090x xxx xxx" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                        <textarea asp-for="Address" class="form-control rounded-4 px-4 py-2" rows="3" placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label d-block fw-bold text-dark mb-2">Phương thức thanh toán</label>
    
                        <div class="p-3 border rounded mb-2 bg-light d-flex align-items-center">
                            <div class="form-check w-100">
                                <input asp-for="PaymentMethod" class="form-check-input" type="radio" value="Tien mat" id="paymentCash" checked />
                                <label class="form-check-label fw-semibold ms-2" for="paymentCash">
                                    💵 Tiền mặt (Thanh toán khi nhận hàng - COD)
                                </label>
                            </div>
                        </div>

                        <div class="p-3 border rounded bg-light d-flex align-items-center">
                            <div class="form-check w-100">
                                <input asp-for="PaymentMethod" class="form-check-input" type="radio" value="Chuyen khoan" id="paymentTransfer" />
                                <label class="form-check-label fw-semibold ms-2" for="paymentTransfer">
                                    💳 Chuyển khoản ngân hàng (Qua mã QR/Banking)
                                </label>
                            </div>
                        </div>
    
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>


                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-dark btn-lg rounded-pill fw-bold py-3">XÁC NHẬN ĐẶT HÀNG</button>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại giỏ hàng</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-5">
            <div class="bg-light p-4 rounded-4 border">
                <h5 class="fw-bold mb-4">Đơn hàng của anh Minh</h5>
                <div class="order-summary-list">
                    @* Duyệt qua giỏ hàng để hiện món *@
                    @foreach (var item in ViewBag.CartItems)
                    {
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                            <div>
                                <span class="fw-bold">@item.Quantity x</span> @item.ProductName
                            </div>
                            <span class="text-success fw-bold">@((item.Price * item.Quantity).ToString("N0"))đ</span>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-between mt-4">
                    <h5 class="fw-bold">TỔNG CỘNG:</h5>
                    <h5 class="text-danger fw-bold">@ViewBag.Total.ToString("N0")đ</h5>
                </div>
            </div>
        </div>
    </div>
</div>
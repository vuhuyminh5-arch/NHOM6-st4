@model List<MilkTea.Models.CartItem>

<div class="container mt-5">
    <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>
    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <p class="fs-4">Giỏ hàng đang trống. Đi mua trà sữa thôi anh Minh ơi!</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-success rounded-pill px-4">QUAY LẠI THỰC ĐƠN</a>
        </div>
    }
    else
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" style="width:50px; border-radius:5px;" class="me-2" />
                            <strong>@item.ProductName</strong>
                        </td>
                        <td>@item.Price.ToString("#,##0") đ</td>
                        <td>@item.Quantity</td>
                        <td class="fw-bold">@item.Total.ToString("#,##0") đ</td>
                        <td><a asp-action="Remove" asp-route-id="@item.ProductId" class="text-danger">Xóa</a></td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="text-end mt-4">
            <h3 class="fw-bold text-success">TỔNG CỘNG: @Model.Sum(x => x.Total).ToString("#,##0") đ</h3>
            <a asp-action="Checkout" class="btn btn-dark btn-lg rounded-pill px-5">THANH TOÁN NGAY</a>
        </div>
    }
</div>
@model IEnumerable<MilkTea.Models.OrderDetail>

<div class="container mt-5">
    <h2 class="fw-bold mb-4">Món ăn trong đơn hàng #@ViewContext.RouteData.Values["id"]</h2>
    <div class="card shadow-sm border-0 rounded-4">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Sản phẩm</th>
                    <th>Số lượng</th>
                    <th class="text-end pe-4">Đơn giá</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <img src="@item.Product?.ImageUrl" style="width:50px;" class="rounded me-2">
                            <strong>@item.Product?.Name</strong>
                        </td>
                        <td>@item.Quantity</td>
                        <td class="text-end pe-4">@item.Price.ToString("#,##0") đ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a asp-action="OrderList" class="btn btn-outline-dark mt-4 rounded-pill">Quay lại danh sách</a>
</div>
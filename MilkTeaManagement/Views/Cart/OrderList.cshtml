@model IEnumerable<MilkTea.Models.Order>

<div class="container mt-5">
    <h2 class="fw-bold mb-4" style="color: #1e3932;">📦 Quản lý vận hành Chất Coffee</h2>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Ngày đặt</th>
                    <th>Khách hàng</th>
                    <th>Trạng thái</th>
                    <th>Tổng tiền</th>
                    <th class="text-center">Thao tác xử lý</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 text-muted">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="fw-bold">@item.FullName</div>
                            <small class="text-muted">@item.Phone</small>
                        </td>
                        <td>
                            @* Tự động đổi màu Badge theo trạng thái *@
                            @{
                                var badgeClass = item.Status == "Chờ xác nhận" ? "bg-warning text-dark" :
                                               item.Status == "Đang pha chế" ? "bg-info" : "bg-success";
                            }
                            <span class="badge @badgeClass rounded-pill px-3">@item.Status</span>
                        </td>
                        <td class="text-danger fw-bold">@item.TotalAmount.ToString("#,##0") đ</td>
                        <td class="text-center">
                            <div class="btn-group border rounded-pill p-1 shadow-sm">
                                <a asp-action="UpdateStatus" asp-route-id="@item.Id" asp-route-status="Đang pha chế" class="btn btn-sm btn-light border-0 text-info" title="Đang làm món">☕</a>
                                <a asp-action="UpdateStatus" asp-route-id="@item.Id" asp-route-status="Đã giao hàng" class="btn btn-sm btn-light border-0 text-success" title="Đã ship xong">✅</a>
                                <a asp-action="OrderDetails" asp-route-id="@item.Id" class="btn btn-sm btn-light border-0" title="Xem chi tiết">👁️</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
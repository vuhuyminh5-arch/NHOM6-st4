@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container text-center py-5" style="min-height: 60vh; display: flex; flex-direction: column; justify-content: center;" data-aos="zoom-in">
    <div class="mb-4">
        @* Icon tích xanh xịn xò *@
        <div class="display-1 text-success mb-4">
            <i class="bi bi-check2-circle"></i>
        </div>
        <h1 class="fw-bold text-uppercase" style="color: #1e3932;">Đặt hàng thành công!</h1>
        <p class="fs-5 text-muted mx-auto" style="max-width: 500px;">
            Cảm ơn anh Minh đã tin tưởng <strong>Chất Coffee</strong>.
            Đơn hàng của anh đang được các Barista ưu tiên pha chế ngay.
        </p>
    </div>

    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Menu" class="btn btn-dark rounded-pill px-5 py-3 fw-bold">TIẾP TỤC MUA SẮM</a>
        <a href="/" class="btn btn-outline-dark rounded-pill px-5 py-3 fw-bold">VỀ TRANG CHỦ</a>
    </div>
</div>
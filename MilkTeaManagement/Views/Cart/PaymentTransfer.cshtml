@model MilkTea.Models.Order
@{
    ViewData["Title"] = "Thanh toán chuyển khoản";
    
    // Cấu hình ngân hàng của anh Minh (Thay bằng thông tin thật của bạn nhé)
    string bankId = "MB"; // Tên viết tắt ngân hàng (VD: Vietcombank, MB, Techcombank, VietinBank)
    string accountNo = "0123456789999"; // Số tài khoản ngân hàng của bạn
    string accountName = "VU HUY MINH"; // Tên chủ tài khoản (viết hoa không dấu)
    
    // Tự động tạo link mã QR theo tiêu chuẩn VietQR quốc gia
    string qrUrl = $"https://img.vietqr.io/image/{bankId}-{accountNo}-compact2.png?amount={Model.TotalAmount}&addInfo=DH{Model.Id}%20{Model.Phone}&accountName={accountName}";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center border p-4 rounded shadow-sm bg-white">
            <h3 class="text-success fw-bold mb-3">🛒 ĐẶT HÀNG THÀNH CÔNG!</h3>
            <p class="text-muted">Mã đơn hàng của bạn là: <strong class="text-dark">#@Model.Id</strong></p>
            <hr />

            <p class="fw-semibold text-danger">Vui lòng quét mã QR dưới đây để thực hiện chuyển khoản:</p>
            
            <div class="my-4">
                <img src="@qrUrl" alt="Mã QR Chuyển khoản" class="img-fluid border p-2 rounded" style="max-width: 300px;" />
            </div>

            <div class="text-start bg-light p-3 rounded mb-4">
                <p class="mb-1">🏦 <strong>Ngân hàng:</strong> @bankId</p>
                <p class="mb-1">💳 <strong>Số tài khoản:</strong> <span class="text-primary fw-bold">@accountNo</span></p>
                <p class="mb-1">👤 <strong>Chủ tài khoản:</strong> @accountName</p>
                <p class="mb-1">💰 <strong>Số tiền:</strong> <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") đ</span></p>
                <p class="mb-0">📝 <strong>Nội dung CK:</strong> <span class="badge bg-dark fs-6">DH @Model.Id</span></p>
            </div>

            <div class="d-grid gap-2">
                <a href="/" class="btn btn-dark btn-lg">Quay về Trang chủ</a>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // Cứ mỗi 3 giây sẽ kiểm tra trạng thái đơn hàng một lần dưới nền
        var checkOrderInterval = setInterval(function () {
            var orderId = @Model.Id;
            
            fetch('/Cart/GetOrderStatus?orderId=' + orderId)
                .then(response => response.json())
                .then(data => {
                    // In dữ liệu ra Console của trình duyệt để bạn tiện kiểm tra
                    console.log("Trạng thái đơn hàng từ API:", data);

                    // ĐỌC TRẠNG THÁI AN TOÀN: Thử lấy cả chữ thường 'status' hoặc chữ hoa 'Status'
                    var currentStatus = data.status || data.Status;

                    // ĐIỀU KIỆN AN TOÀN MỚI:
                    // Phải tìm thấy trạng thái hợp lệ VÀ trạng thái đó phải KHÁC 'Cho xac nhan' thì mới chuyển trang
                    if (currentStatus && currentStatus !== "Cho xac nhan") {
                        clearInterval(checkOrderInterval); // Dừng chạy ngầm
                        window.location.href = '/Cart/OrderSuccess'; // Chuyển sang trang thành công
                    }
                })
                .catch(error => console.error("Lỗi kết nối API:", error));
        }, 3000);
    </script>
}
}
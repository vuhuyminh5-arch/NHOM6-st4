@model IEnumerable<MilkTea.Models.Product>
@{
    ViewData["Title"] = "Thực Đơn - CHẤT COFFEE";
}

<div class="container my-5">
    <div class="text-center mb-5" data-aos="fade-down">
        <h2 class="display-5 fw-bold" style="color: #1e3932;">THỰC ĐƠN HÔM NAY</h2>
        <div class="mx-auto" style="width: 60px; height: 3px; background: #cba258;"></div>
    </div>

    <div class="text-center mb-4" data-aos="fade-up">
        <div class="d-inline-flex p-2 bg-light rounded-pill shadow-sm">
            <a href="@Url.Action("Menu", "Home")" class="btn btn-dark rounded-pill px-4 me-2">Tất cả</a>
            @if (ViewBag.Categories != null) {
                foreach (var cat in ViewBag.Categories) {
                    <a href="@Url.Action("Menu", "Home", new { categoryId = cat.Id })" 
                       class="btn btn-outline-dark border-0 rounded-pill px-4 mx-1">@cat.Name</a>
                }
            }
        </div>
    </div>

    <form asp-action="Menu" method="get" class="d-flex justify-content-center mb-5" data-aos="fade-up" data-aos-delay="100">
        <div class="input-group" style="max-width: 600px;">
            <input type="text" name="searchTerm" class="form-control rounded-start-pill ps-4 shadow-sm border-end-0" placeholder="Anh Minh muốn tìm món gì?">
            <button type="submit" class="btn btn-dark rounded-end-pill px-4 shadow-sm fw-bold">TÌM KIẾM</button>
        </div>
    </form>

    <div class="row g-4">
        @foreach (var item in Model) {
            <div class="col-6 col-md-4 col-lg-3" data-aos="zoom-in">
                <div class="card h-100 border-0 shadow-sm product-card rounded-4 overflow-hidden">
                    <div class="position-relative overflow-hidden" style="height: 220px;">
                        <img src="@item.ImageUrl" class="card-img-top h-100 w-100 transition-img" style="object-fit: cover;">
                    </div>
                    <div class="card-body text-center d-flex flex-column justify-content-between">
                       <h6 class="fw-bold mb-1">@item.Name</h6>

<p class="text-muted small mb-2">@(item.Category?.Name ?? "Chưa phân loại")</p>
                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" 
                           class="btn btn-dark btn-sm rounded-pill px-4 btn-add-cart w-100 py-2 fw-bold">MUA NGAY</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card { transition: all 0.4s ease; border: 1px solid rgba(0,0,0,0.05) !important; }
    .product-card:hover { transform: translateY(-12px); box-shadow: 0 20px 40px rgba(30, 57, 50, 0.15) !important; }
    .transition-img { transition: transform 0.6s ease; }
    .product-card:hover .transition-img { transform: scale(1.1); }
</style>
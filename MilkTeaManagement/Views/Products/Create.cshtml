@model MilkTea.Models.Product

<div class="container mt-5" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <h2 class="fw-bold mb-4" style="color: #1e3932;">🆕 Đăng món mới vào Menu</h2>
                
                <form asp-action="Create" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên món nước</label>
                            <input asp-for="Name" class="form-control rounded-pill px-4 py-2 border-2" placeholder="Ví dụ: Matcha Latte...">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                                <input asp-for="Price" class="form-control rounded-pill px-4 py-2 border-2" type="number">
                                </div>
                                <div class="col-md-12 mb-4">
                                    <label class="form-label fw-bold">Chọn ảnh từ máy tính</label>
                                    <input type="file" name="ImageFile" class="form-control rounded-4 p-3 border-dashed">
                                    <small class="text-muted">Nên chọn ảnh vuông, nền trắng (PNG) để nhìn đẹp nhất.</small>
                                </div>
                            </div>
                    
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 fw-bold shadow">XÁC NHẬN ĐĂNG</button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">Hủy</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
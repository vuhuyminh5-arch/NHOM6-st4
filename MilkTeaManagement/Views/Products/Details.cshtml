@model MilkTea.Models.Product
<div class="container mt-5 pt-4" data-aos="zoom-in">
    <div class="row align-items-center bg-white p-5 rounded-4 shadow-sm border">
        @* Cột chứa ảnh *@
        <div class="col-md-5 text-center">
            <img src="@Model.ImageUrl" class="img-fluid rounded-4 shadow" style="max-height: 400px; object-fit: contain;">
        </div>
        
        @* Cột chứa thông tin *@
        <div class="col-md-7 ps-lg-5 mt-4 mt-md-0">
            <span class="badge bg-success mb-2 px-3 py-2 rounded-pill">@Model.Category?.Name</span>
            <h1 class="fw-bold" style="color: #1e3932;">@Model.Name</h1>
            <h2 class="text-danger fw-bold my-3">@Model.Price.ToString("#,##0") đ</h2>
            
            <p class="text-muted" style="line-height: 1.8;">
                Thức uống mang hương vị đặc trưng của Chất Coffee. Được pha chế từ những nguyên liệu tươi ngon nhất, cam kết mang lại cho bạn trải nghiệm tuyệt vời.
            </p>

            <hr class="my-4">

            <div class="d-flex align-items-center gap-3">
                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn btn-dark btn-lg rounded-pill px-5 fw-bold shadow-sm" style="background-color: #1e3932;">
                    + THÊM VÀO GIỎ
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                   Quay lại menu
                </a>
            </div>
        </div>
    </div>
</div>
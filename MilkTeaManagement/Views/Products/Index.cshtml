@{
    Layout = "_Layout";
}
@model IEnumerable<MilkTea.Models.Product>
<div class="row mb-5 align-items-center shadow-sm" style="background-color: #d4e9e2; border-radius: 20px; min-height: 300px;">
    <div class="col-md-6 px-5 py-5 text-center text-md-start">
        <h1 class="display-4 fw-bold" style="color: #1e3932;">Chào mừng đến với <br /> Chất Coffee</h1>
        <p class="fs-5 mt-3" style="color: #1e3932;">Thưởng thức hương vị cà phê nguyên bản, <br /> được tuyển chọn từ những hạt cà phê chất lượng nhất.</p>
        <button class="btn btn-dark rounded-pill mt-3 px-4">Tìm hiểu thêm</button>
    </div>
    <div class="col-md-6 text-center">
<a asp-action="Index">
        <img src="https://www.starbucks.com.vn/media/2021/09/Caramel-Macchiato.png" style="max-height: 350px;" />
   </a>
 </div>
</div>
<div class="container mt-n4 position-relative" style="z-index: 10;">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <form asp-action="Index" method="get" class="row g-0 align-items-center shadow-lg bg-white rounded-pill p-2 border">
                <div class="col-md-5">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                           class="form-control border-0 px-4 mt-1" style="box-shadow: none;" placeholder="Tìm món ngon tại Chất Coffee..." />
                </div>
                
                <div class="col-md-4 border-start">
                    <select name="categoryId" class="form-select border-0 px-4" style="box-shadow: none;" asp-items="ViewBag.CategoryId">
                        <option value="">Tất cả loại đồ uống</option>
                    </select>
                </div>

                <div class="col-md-3 text-end">
                    <button type="submit" class="btn btn-dark rounded-pill px-5 w-100 fw-bold py-2">TÌM KIẾM</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="container mb-5" data-aos="flip-up">
    <div class="card border-0 rounded-4 text-white p-4 shadow-lg position-relative overflow-hidden" 
         style="background: linear-gradient(135deg, #1e3932 0%, #2d5a4c 100%); max-width: 450px;">
        
        <div class="position-absolute" style="width: 100px; height: 300px; background: rgba(255,255,255,0.1); transform: rotate(45deg); top: -50px; right: 50px;"></div>

        <div class="d-flex justify-content-between align-items-start position-relative">
            <div>
                <h6 class="mb-0 fw-light" style="letter-spacing: 2px;">CHẤT COFFEE MEMBER</h6>
                <h4 class="fw-bold mt-2 text-uppercase">@User.Identity?.Name</h4> 
                @if (string.IsNullOrEmpty(User.Identity?.Name)) { <h4 class="fw-bold mt-2">VŨ HUY MINH</h4> }
            </div>
            <i class="bi bi-qr-code-scan fs-1"></i>
        </div>

        <div class="mt-4 position-relative">
            <p class="mb-1 small opacity-75">SỐ SAO TÍCH LŨY</p>
            <h3 class="fw-bold">1,250 <i class="bi bi-star-fill text-warning fs-4"></i></h3>
        </div>

        <div class="mt-3">
            <div class="progress" style="height: 6px; background: rgba(255,255,255,0.2);">
                <div class="progress-bar bg-warning" style="width: 75%"></div>
            </div>
            <p class="mt-2 small mb-0">Còn 250 sao nữa để nhận **1 ly miễn phí**!</p>
        </div>
    </div>
</div>
<div class="container-fluid bg-light py-5 mb-5" style="background: linear-gradient(135deg, #e6f2ee 0%, #ffffff 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6" data-aos="fade-right">
                <h1 class="display-4 fw-bold text-dark">Chào mừng đến với <br><span style="color: #1e3932;">Chất Coffee</span></h1>
                <p class="lead text-muted">Thưởng thức hương vị cà phê nguyên bản, được tuyển chọn từ những hạt cà phê chất lượng nhất.</p>
                <a href="#menu" class="btn btn-dark btn-lg rounded-pill px-4 mt-3 shadow">Tìm hiểu thêm</a>
            </div>
            <div class="col-md-6 text-center" data-aos="fade-left">
                <img src="https://www.starbucks.com.vn/media/2021/09/Caramel-Macchiato.png" 
                     class="img-fluid floating-img" style="max-height: 350px; filter: drop-shadow(0 15px 15px rgba(0,0,0,0.1));">
            </div>
        </div>
    </div>
</div>
  <div class="row mt-4" id="menu">
    @{ int i = 0; } 

    @foreach (var item in Model)
    {
        
        <div class="col-lg-3 col-md-4 col-6 mb-4" data-aos="fade-up" data-aos-delay="@(i * 100)">
            <div class="card h-100 border-0 shadow-sm rounded-4 product-card overflow-hidden">
                <div class="position-relative bg-light p-3">
                    <img src="@item.ImageUrl" class="card-img-top img-fluid" style="height: 180px; object-fit: contain;">
                </div>
                <div class="card-body text-center p-3">
                    <h6 class="fw-bold mb-1">@item.Name</h6>
                    <p class="text-success fw-bold mb-2">@item.Price.ToString("#,##0") đ</p>

                    <div class="d-flex justify-content-center mt-2">
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn-delete-mini"
                           onclick="return confirm('Bạn có chắc chắn muốn xóa món này không?')">
                            Xóa món
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        i++;
    }
<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-up">
    <h2 class="fw-bold">Thực đơn của bạn</h2>
    
    <a asp-action="Create" class="btn btn-dark rounded-pill px-4 py-2 shadow-sm fw-bold">
        <i class="bi bi-plus-lg"></i> NHẬP MÓN MỚI
    </a>
</div>

<p class="text-muted mb-4">Khám phá những hương vị đặc trưng nhất từ Chất Coffee</p>

<div class="row justify-content-center mb-5" data-aos="fade-up" data-aos-delay="100">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex bg-white rounded-pill shadow-sm p-1 border">
            <input type="text" name="searchString" class="form-control border-0 rounded-pill px-4" placeholder="Bạn muốn uống gì hôm nay?..." value="@ViewData["CurrentFilter"]">
            <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold" style="background-color: #1e3932;">TÌM KIẾM</button>
        </form>
    </div>
</div>
</div>

<style>
    body { background-color: #f7f7f7; font-family: 'SoDo Sans', Helvetica, Arial, sans-serif; }
    .card:hover { transform: translateY(-5px); transition: 0.3s; cursor: pointer; }
    .btn-outline-success { color: #006241; border-color: #006241; }
    .btn-outline-success:hover { background-color: #006241; color: white; }
    .btn-delete-mini {
        padding: 4px 15px;
        font-size: 0.75rem;
        color: #dc3545;
        border: 1px solid #dc3545;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.3s ease;
        background-color: transparent;
        font-weight: 600;
    }

        .btn-delete-mini:hover {
            background-color: #dc3545;
            color: white !important;
            box-shadow: 0 4px 8px rgba(220, 53, 69, 0.2);
        }
</style>
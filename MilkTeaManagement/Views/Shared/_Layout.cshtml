<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CHẤT COFFEE</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .navbar {
    background: rgba(255, 255, 255, 0.8) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,0.05);
}
.floating-cart {
    position: fixed; bottom: 30px; right: 30px;
    width: 60px; height: 60px; background: #1e3932;
    color: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    z-index: 1000; transition: 0.3s;
}
        :root { --primary-green: #1e3932; --accent-gold: #cba258; }
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar-brand { color: var(--primary-green) !important; font-weight: 700; }
        .nav-link { font-weight: 600; text-transform: uppercase; font-size: 0.8rem; color: #333 !important; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fs-3" asp-controller="Home" asp-action="Index">
                    CHẤT <span style="color: var(--accent-gold);">COFFEE.</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        
    <li class="nav-item">
        <a class="nav-link text-dark px-3 fw-bold" asp-controller="Home" asp-action="Index">TRANG CHỦ</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark px-3 fw-bold" asp-controller="Home" asp-action="Menu">THỰC ĐƠN</a>
    </li>


    @if (User.IsInRole("Admin"))
    {
        <li class="nav-item dropdown ms-lg-2">
            <a class="nav-link dropdown-toggle text-danger fw-bold border border-danger rounded-pill px-3" 
               href="#" id="adminDb" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                🛠️ QUẢN TRỊ
            </a>
            <ul class="dropdown-menu border-0 shadow-lg rounded-3">
                <li><a class="dropdown-item py-2" asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Kho Sản Phẩm</a></li>
                <li><a class="dropdown-item py-2" asp-controller="Cart" asp-action="OrderList"><i class="bi bi-receipt me-2"></i>Đơn Hàng</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item py-2 text-primary" asp-controller="Products" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Thêm Món Mới</a></li>
            </ul>
        </li>
    }

                    </ul>

                    <partial name="_LoginPartial" />

                    <div class="ms-3">
    <a asp-controller="Cart" asp-action="Index" class="btn position-relative">
        <i class="bi bi-bag-heart fs-4"></i>
        @{
            // Đọc thử cả chữ C viết hoa và c viết thường để chống sót lỗi
            var cartJson = Context.Session.GetString("Cart") ?? Context.Session.GetString("cart");
            var cartCount = 0;
            if (cartJson != null)
            {
                var cartItems = System.Text.Json.JsonSerializer.Deserialize<List<MilkTea.Models.CartItem>>(cartJson);
                cartCount = cartItems?.Sum(x => x.Quantity) ?? 0;
            }
        }
        
        @if (cartCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @cartCount
            </span>
        }
    </a>
</div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container mt-4 pb-5">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted py-3 bg-white text-center mt-auto">
        <div class="container">&copy; 2026 - CHẤT COFFEE</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    AOS.init({ duration: 1000, once: true });

    document.querySelectorAll('.btn-add-cart').forEach(btn => {
        btn.addEventListener('click', function() {
            Swal.fire({
                icon: 'success',
                title: 'Đã thêm vào giỏ!',
                text: 'Chất Coffee đang chuẩn bị món cho anh Minh.',
                timer: 1500,
                showConfirmButton: false
            });
        });
    });
</script>
</body>
</html>